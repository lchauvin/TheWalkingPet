# Database
POSTGRES_USER=twp
POSTGRES_PASSWORD=twp_secret
POSTGRES_DB=thewalkingpet
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
JWT_SECRET_KEY=change_me_to_a_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (get from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Firebase (download from Firebase Console → Project Settings → Service Accounts → Generate new private key)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Storage
STORAGE_PATH=./storage/images

# ML
MODEL_CHECKPOINT_PATH=./models/triplet_net.pt
YOLO_MODEL=yolov8m-seg.pt
EMBEDDING_DIM=256

# App
DEBUG=false
